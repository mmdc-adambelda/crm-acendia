# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twilio (voice calling only)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_API_KEY=your-api-key-sid
TWILIO_API_SECRET=your-api-key-secret
TWILIO_TWIML_APP_SID=your-twiml-app-sid
TWILIO_PHONE_1=+15551234567
TWILIO_PHONE_2=

# Sonetel (AU voice calling — callback style, used for leads with country = Australia)
SONETEL_USERNAME=your-sonetel-account-email
SONETEL_PASSWORD=your-sonetel-account-password
# The verified Sonetel AU number shown as caller ID to the lead
SONETEL_CALLER_ID=+61290995664

# Mocean (SMS — manual sends + appointment reminders)
MOCEAN_API_KEY=your-mocean-api-key
MOCEAN_API_SECRET=your-mocean-api-secret
# Sender ID shown to recipients (e.g. "Acendia") — required by Mocean
MOCEAN_SMS_FROM=Acendia

# Gmail API (email — sends via Google Workspace domain-wide delegation)
# Service account credentials from the JSON key downloaded in Google Cloud Console.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON key as-is — keep the \n sequences literal.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Real Workspace mailbox to impersonate for automated reminder emails (manual sends
# instead impersonate whichever rep is logged in, using their own CRM login email).
GMAIL_REMINDER_SENDER=notifications@acendia.agency

# Cron auth (Vercel Cron → /api/cron/appointment-reminders)
CRON_SECRET=your-cron-secret
