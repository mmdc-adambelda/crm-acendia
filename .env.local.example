# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twilio (voice calling only)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_API_KEY=your-api-key-sid
TWILIO_API_SECRET=your-api-key-secret
TWILIO_TWIML_APP_SID=your-twiml-app-sid
TWILIO_PHONE_1=+15551234567
TWILIO_PHONE_2=

# ClickSend (SMS — manual sends + appointment reminders)
CLICKSEND_USERNAME=your-clicksend-username
CLICKSEND_API_KEY=your-clicksend-api-key
# Optional — Sender ID / dedicated number. Leave unset to use ClickSend's shared/random sender.
CLICKSEND_SMS_FROM=

# Resend (email)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron auth (Vercel Cron → /api/cron/appointment-reminders)
CRON_SECRET=your-cron-secret
